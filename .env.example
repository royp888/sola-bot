SOLA_APP_NAME=sola
SOLA_APP_ENV=production
SOLA_APP_HTTP_ADDR=:8080
SOLA_APP_ADMIN_USERNAME=admin
SOLA_APP_ADMIN_PASSWORD=change-this-admin-password
# Preferred in production: generate with `htpasswd -bnBC 12 "" your-password | tr -d ":\n"`
SOLA_APP_ADMIN_PASSWORD_HASH=
SOLA_APP_ENABLE_SWAGGER=false
SOLA_APP_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

SOLA_BOT_TOKEN=replace-with-telegram-bot-token
SOLA_BOT_MODE=polling
SOLA_BOT_DEFAULT_LOCALE=zh-CN
SOLA_BOT_MINI_APP_URL=

SOLA_DATABASE_NAME=sola
SOLA_DATABASE_USER=sola
SOLA_DATABASE_PASSWORD=change-this-database-password
SOLA_DATABASE_DSN=postgres://sola:change-this-database-password@postgres:5432/sola?sslmode=disable
SOLA_DATABASE_AUTO_MIGRATE=false
SOLA_DATABASE_MAX_OPEN_CONNS=20
SOLA_DATABASE_MAX_IDLE_CONNS=5
SOLA_DATABASE_CONN_MAX_LIFETIME=30m

SOLA_REDIS_ADDR=redis:6379
SOLA_REDIS_PASSWORD=
SOLA_REDIS_DB=0

SOLA_JWT_SECRET=replace-with-a-long-random-secret
SOLA_JWT_ISSUER=sola-admin
SOLA_JWT_ACCESS_TOKEN_TTL=24h

SOLA_HTTP_PORT=80

# AI 垃圾广告检测（可选）
SOLA_AI_FILTER_ENABLED=false
SOLA_AI_FILTER_PROVIDER=deepseek
SOLA_AI_FILTER_API_KEY=
SOLA_AI_FILTER_MODEL=deepseek-chat
SOLA_AI_FILTER_ENDPOINT=https://api.deepseek.com/v1
